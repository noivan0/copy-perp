# ── Copy Perp 환경설정 템플릿 ─────────────────────────
# 이 파일을 복사하여 .env로 사용 (git에 .env는 커밋하지 말 것)

# ── 네트워크 선택 ──────────────────────────────────────
NETWORK=testnet   # testnet | mainnet

# ── Testnet ────────────────────────────────────────────
TESTNET_REST_URL=https://test-api.pacifica.fi/api/v1
TESTNET_CF_URL=https://do5jt23sqak4.cloudfront.net
TESTNET_WS_URL=wss://test-ws.pacifica.fi/ws
TESTNET_APP_URL=https://test-app.pacifica.fi

# ── Mainnet ────────────────────────────────────────────
MAINNET_REST_URL=https://api.pacifica.fi/api/v1
MAINNET_WS_URL=wss://ws.pacifica.fi/ws
MAINNET_APP_URL=https://app.pacifica.fi

# ── 계정 (교체 필요) ──────────────────────────────────
ACCOUNT_ADDRESS=YOUR_ACCOUNT_ADDRESS
AGENT_WALLET=YOUR_AGENT_WALLET_PUBKEY
AGENT_PRIVATE_KEY=YOUR_AGENT_PRIVATE_KEY_BASE58

# ── Builder Program ────────────────────────────────────
BUILDER_CODE=noivan
BUILDER_FEE_RATE=0.001

# ── Copy Engine 설정 ──────────────────────────────────
COPY_RATIO=0.10
MAX_POSITION_USDC=50
STOP_LOSS_PCT=-0.10

# ── 외부 서비스 ────────────────────────────────────────
PRIVY_APP_ID=                    # privy.io 앱 ID
FUUL_API_KEY=                    # Fuul API 키 (없으면 Mock)
FUUL_PROJECT_ID=                 # Fuul 프로젝트 ID

# ── 알림 (선택) ────────────────────────────────────────
ALERT_TELEGRAM_TOKEN=            # 텔레그램 봇 토큰 (주문 실패 알림)
ALERT_TELEGRAM_CHAT_ID=          # 텔레그램 채팅 ID

# ── DB ─────────────────────────────────────────────────
DB_PATH=/absolute/path/to/copy_perp.db
