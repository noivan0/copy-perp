# ══════════════════════════════════════════════════
# Copy Perp — 환경변수 전체 목록 (2026-04-13 최신화)
# 복사 후 실제 값 입력: cp .env.example .env
# ⚠️ .env는 절대 git commit 금지
# ══════════════════════════════════════════════════

# ── 네트워크 선택 ────────────────────────────────
NETWORK=mainnet

# ── Testnet 설정 ─────────────────────────────────
TESTNET_REST_URL=https://test-api.pacifica.fi/api/v1
TESTNET_CF_URL=https://do5jt23sqak4.cloudfront.net
TESTNET_WS_URL=wss://test-ws.pacifica.fi/ws
TESTNET_APP_URL=https://test-app.pacifica.fi

# ── Mainnet 설정 ─────────────────────────────────
MAINNET_REST_URL=https://api.pacifica.fi/api/v1
MAINNET_WS_URL=wss://ws.pacifica.fi/ws
MAINNET_APP_URL=https://app.pacifica.fi
PACIFICA_REST_URL=https://api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
# HMG 방화벽 우회: 직접 접근 여부
PACIFICA_DIRECT=false
# SSL 검증 (프로덕션: true / HMG 방화벽 환경만 false)
PACIFICA_VERIFY_SSL=true

# ── 계정 (필수) ──────────────────────────────────
# 서버 주계정 Solana 주소 (Pacifica 자산 보유)
ACCOUNT_ADDRESS=
# Agent Key 비밀키 (주문 서명 전용)
AGENT_PRIVATE_KEY=
# Agent Key 공개키 (서명 검증용)
AGENT_WALLET=

# ── Builder Program ──────────────────────────────
BUILDER_CODE=noivan
BUILDER_FEE_RATE=0.001

# ── Copy Engine 기본값 ───────────────────────────
COPY_RATIO=0.10
MAX_POSITION_USDC=300
STOP_LOSS_PCT=-0.10

# ── Privy 인증 (필수) ────────────────────────────
# dashboard.privy.io 에서 발급
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/YOUR_APP_ID/jwks.json

# ── DB ──────────────────────────────────────────
# 로컬 SQLite (개발용)
DB_PATH=copy_perp.db
# Turso 클라우드 DB (프로덕션 권장)
TURSO_URL=
TURSO_TOKEN=

# ── 보안 / Admin ─────────────────────────────────
# Admin API 엔드포인트 활성화 키 (미설정 시 비활성)
ADMIN_API_KEY=
# JWT 없는 팔로우 해지 차단 (프로덕션: true)
REQUIRE_AUTH=true
# 프록시 IP 신뢰 CIDR (Render: 10.0.0.0/8)
TRUSTED_PROXY_IPS=10.0.0.0/8
# 최대 요청 바디 크기 (bytes, 기본 1MB)
MAX_BODY_SIZE_BYTES=1048576

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:3000,https://copy-perp-frontend.vercel.app,https://copy-perp.onrender.com

# ── 알림 (텔레그램, 선택) ────────────────────────
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# ── 개발/디버그 ──────────────────────────────────
# 프로덕션: 반드시 false (docs 노출 방지)
DEBUG=false
