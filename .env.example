# Copy Perp — Environment Variables
# Copy this file to .env and fill in your values

# ── Network ────────────────────────────────────────
NETWORK=testnet                        # testnet | mainnet

# ── Testnet Endpoints ──────────────────────────────
TESTNET_REST_URL=https://test-api.pacifica.fi/api/v1
TESTNET_WS_URL=wss://test-ws.pacifica.fi/ws
TESTNET_APP_URL=https://test-app.pacifica.fi

# ── Mainnet Endpoints ──────────────────────────────
MAINNET_REST_URL=https://api.pacifica.fi/api/v1
MAINNET_WS_URL=wss://ws.pacifica.fi/ws
MAINNET_APP_URL=https://app.pacifica.fi

# ── Account (Required) ─────────────────────────────
ACCOUNT_ADDRESS=<your_solana_wallet_address>   # Privy 지갑 주소 (자산 보유)
AGENT_WALLET=<your_agent_public_key>           # Agent Key 공개키 (서명 전용)
AGENT_PRIVATE_KEY=<your_agent_private_key>     # Agent Key 개인키 ⚠️ 절대 공개 금지

# ── Builder Program ────────────────────────────────
BUILDER_CODE=noivan                    # 수수료 수취 코드
BUILDER_FEE_RATE=0.001                # 0.1%

# ── Copy Engine ────────────────────────────────────
COPY_RATIO=0.10                        # 팔로워 잔고 대비 복사 비율 (10%)
MAX_POSITION_USDC=50                   # 최대 포지션 크기 (USDC)
STOP_LOSS_PCT=-0.10                    # 손절 기준 (-10%)

# ── External Services ──────────────────────────────
PRIVY_APP_ID=<your_privy_app_id>       # dashboard.privy.io 에서 발급
# FUUL_PROJECT_ID=                     # Fuul 레퍼럴 (선택)

# ── Database ───────────────────────────────────────
DB_PATH=copy_perp.db                   # SQLite DB 경로

# ── CORS ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:3000

# ── Debug ──────────────────────────────────────────
# DEBUG=true                           # /docs, /redoc 엔드포인트 활성화 (개발 전용)
